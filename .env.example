# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# LLM provider — Groq (OpenAI-compatible), free tier by default
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL_NAME=qwen/qwen3-32b

# Supabase / pgvector
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# AST analyzer (persistent Bun service)
AST_SERVICE_URL=http://localhost:4000

# Graph behavior bounds — deterministic, not tuned at runtime
HALLUCINATION_RETRY_CAP=3
REVIEW_LATENCY_BUDGET_SECONDS=60
